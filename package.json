{
  "name": "ng-a2ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "web": "ng serve --open",
    "agent": "node --env-file=.env --import tsx server/index.ts",
    "dev": "concurrently -n web,agent -c indigo,green \"npm:web\" \"npm:agent\"",
    "build": "ng build"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@genkit-ai/google-genai": "^1.33.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "genkit": "^1.33.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.14",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
